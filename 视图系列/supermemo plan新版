// 格式化时间为yyyy/MM/dd HH:mm:ss格式
function formatDateForTimestamp(date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  const hours = String(date.getHours()).padStart(2, '0');
  const minutes = String(date.getMinutes()).padStart(2, '0');
  const seconds = String(date.getSeconds()).padStart(2, '0');
  
  return `${year}/${month}/${day} ${hours}:${minutes}:${seconds}`;
}

// 计划完成时转换为记录 - 修复评价记录到当前活动而非下一活动
// 计划完成时转换为记录 - 修复评价记录到当前活动而非下一活动
function convertPhaseToEntries(phase) {
  const newEntries = [];
  
  // 获取所有已完成的活动
  const completedActivities = phase.activities.filter(activity => 
    activity.status === 'completed' && activity.actualStart && activity.actualEnd
  ).sort((a, b) => new Date(b.actualStart) - new Date(a.actualStart)); // 按开始时间倒序排序
  
  // 添加特殊的结尾记录，标记时间阶段完成
  const endTime = new Date();
  const endEntry = {
    timestamp: formatDateForTimestamp(endTime),
    project: "**阶段结束**未记录", // 修改：添加阶段结束标记
    prevExperience: "一个时间段完成了",
    prevRating: 0
  };
  
  // 将最后一个完成活动的评价放到"未记录"条目中
  if (completedActivities.length > 0) {
    const lastActivity = completedActivities[0]; // 最近完成的活动
    endEntry.prevExperience = lastActivity.experience || "未记录";
    endEntry.prevRating = Number(lastActivity.rating) || 0;
  }
  
  newEntries.push(endEntry);
  
  // 处理所有完成的活动，将每个活动的评价赋给下一个活动的prevExperience
  for (let i = 0; i < completedActivities.length; i++) {
    const currentActivity = completedActivities[i];
    const startTime = new Date(currentActivity.actualStart);
    
    const newEntry = {
      timestamp: formatDateForTimestamp(startTime),
      project: currentActivity.project,
      prevExperience: "未记录",
      prevRating: 0
    };
    
    // 如果不是第一个活动，则使用前一个活动的评价
    if (i < completedActivities.length - 1) {
      const prevActivity = completedActivities[i + 1]; // 因为是倒序，所以i+1是前一个
      newEntry.prevExperience = prevActivity.experience || "未记录";
      newEntry.prevRating = Number(prevActivity.rating) || 0;
    }
    
    newEntries.push(newEntry);
  }
  
  // 修改：为最后一个条目（阶段开始）添加标记 - 无条件添加
  if (newEntries.length > 1) {
    const lastEntry = newEntries[newEntries.length - 1];
    // 无条件为最后一个条目添加阶段开始标记
    lastEntry.project = "**阶段开始**" + lastEntry.project;
  }
  
  return newEntries;
}

// 从YAML恢复活动计划（增强修复版 - 修复了无法找到activityPlan数组的问题）
async function restoreFromActivityPlan() {
  // 保存当前状态以便错误时恢复
  const backupPhase = currentPhase ? JSON.parse(JSON.stringify(currentPhase)) : null;
  const backupUIState = JSON.parse(JSON.stringify(lastUIState));
  
  try {
    // 显示加载中状态
    statusEl.innerHTML = '';
    statusEl.createEl("div", {
      text: "正在从备份恢复...",
      attr: {style: "color: blue; background-color: #e3f2fd; padding: 8px; border-radius: 3px; margin: 10px 0;"}
    });
    
    // 检查Obsidian API是否可用
    if (typeof app === 'undefined' || !app) {
      throw new Error("无法访问Obsidian API (app未定义)");
    }
    
    if (!app.vault) {
      throw new Error("无法访问Obsidian文件系统 (app.vault未定义)");
    }
    
 const currentFile = await getTargetFile();
    
    // 安全读取文件内容
    let fileContent;
    try {
      fileContent = await app.vault.read(currentFile);
    } catch (readError) {
      console.error("读取文件内容失败:", readError);
      throw new Error("无法读取文件内容: " + (readError.message || "未知错误"));
    }
    
    if (!fileContent || fileContent.trim() === "") {
      throw new Error("文件内容为空");
    }
    
    if (!fileContent.startsWith('---\n')) {
      throw new Error("未找到YAML前置元数据 (文件未以---\\n开头)");
    }
    
    // 提取YAML部分
    const yamlEnd = fileContent.indexOf('\n---\n');
    if (yamlEnd <= 0) {
      throw new Error("YAML格式错误 (找不到结束标记)");
    }
    
    // 提取整个YAML内容
    const yamlSection = fileContent.substring(4, yamlEnd);
    console.log("提取的YAML内容长度:", yamlSection.length, "字节");
    
    // 首先尝试查找activityPlan标记
    if (!yamlSection.includes('activityPlan:')) {
      throw new Error("YAML中未包含activityPlan关键字");
    }
    
    // 使用多种正则表达式尝试不同格式的匹配
    let activityPlanData = null;
    
    // 方法1: 使用更宽松的正则表达式
    try {
      // 方法1: 匹配 activityPlan: 后面的所有内容直到结束或下一个顶级属性
      const looserRegex = /activityPlan:\s*($$[\s\S]*?)(?:\n\S+:|$)/;
      const match1 = yamlSection.match(looserRegex);
      
      if (match1 && match1[1]) {
        const jsonStr = match1[1].trim();
        console.log("方法1找到的可能JSON长度:", jsonStr.length);
        
        // 检查是否是有效的JSON数组开始
        if (jsonStr.startsWith('[') && (jsonStr.endsWith(']') || jsonStr.includes(']'))) {
          // 如果JSON字符串不以]结尾，尝试查找最后的]
          let validJsonStr = jsonStr;
          if (!jsonStr.endsWith(']')) {
            const lastBracketPos = jsonStr.lastIndexOf(']');
            if (lastBracketPos > 0) {
              validJsonStr = jsonStr.substring(0, lastBracketPos + 1);
            } else {
              // 没有找到结束括号，尝试添加
              validJsonStr = jsonStr + ']';
            }
          }
          
          try {
            activityPlanData = JSON.parse(validJsonStr);
            console.log("方法1成功解析JSON数组，长度:", activityPlanData.length);
          } catch (parseErr) {
