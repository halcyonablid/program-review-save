function positionReviewForm(anchorEl) {
  const containerRect = containerEl.getBoundingClientRect();
  const formRect = reviewFormEl.getBoundingClientRect();
  const edgePadding = 12;
  const panelWidth = formRect.width;
  const maxLeft = Math.max(edgePadding, containerRect.width - panelWidth - edgePadding);

  let left = Math.min(
    maxLeft,
    Math.max(edgePadding, Math.round((containerRect.width - panelWidth) / 2))
  );
  let top = edgePadding;

  if (anchorEl) {
    const anchorRect = anchorEl.getBoundingClientRect();
    top = anchorRect.top - containerRect.top;

    const maxTop = Math.max(edgePadding, containerEl.offsetHeight - formRect.height - edgePadding);
    if (top > maxTop) {
      top = Math.max(edgePadding, anchorRect.bottom - containerRect.top - formRect.height);
    }
  }

  reviewFormEl.style.left = `${Math.round(left)}px`;
  reviewFormEl.style.top = `${Math.round(Math.max(edgePadding, top))}px`;
}

