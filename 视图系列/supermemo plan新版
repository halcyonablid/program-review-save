const { Modal, Notice } = require('obsidian');


class AddActivityModal extends Modal {
  // 构造函数接收 app 实例, 目标索引, 以及一个成功提交后的回调函数
  constructor(app, afterIndex, onSubmit) {
    super(app);
    this.afterIndex = afterIndex;
    this.onSubmit = onSubmit;
  }

  // onOpen 是 Modal 的生命周期方法，当窗口打开时自动执行
  onOpen() {
    const { contentEl } = this; // contentEl 是 Modal 提供的一个安全的、用于填充内容的 HTML 元素
    if (this.modalEl) {
      this.modalEl.style.width = "980px";
      this.modalEl.style.maxWidth = "94vw";
    }

    // --- 开始构建模态窗口的内部 UI ---

    // 1. 设置标题
    const targetActivity = currentPhase.activities[this.afterIndex];
    if (!targetActivity) {
      // 这是一个额外的安全检查，尽管外部已做过
      contentEl.createEl('h4', { text: '错误：找不到目标活动' });
      return;
    }
    contentEl.createEl('h4', { 
      text: `在 "${targetActivity.project}" 后添加新活动`,
      cls: 'modal-title' // 可以添加自定义类名以便CSS美化
    }).style.marginBottom = "15px";
    contentEl.createEl("div", {
      text: "这里先把待执行任务尽量完整地写下来，后续再在执行中调整顺序和时长。",
      attr: { style: "margin-bottom: 18px; color: var(--text-muted); line-height: 1.7;" }
    });

    // 2. 添加活动名称输入区域 (使用 textarea)
    contentEl.createEl('label', { 
      text: '活动名称:', 
      cls: 'modal-label' 
    }).style.fontWeight = "bold";
    
    const nameInput = contentEl.createEl('textarea');
    nameInput.setAttrs({
      "placeholder": "请输入活动名称（可输入最多1000字）",
      "maxlength": "1000"
    });
    // 设置样式
    Object.assign(nameInput.style, {
      width: "100%",
      minHeight: "300px",
      height: "300px",
      padding: "14px",
      fontSize: "17px",
      lineHeight: "1.75",
      resize: "vertical",
      marginTop: "5px",
      marginBottom: "15px"
    });

    // 3. 添加时长输入区域
    contentEl.createEl('label', { 
      text: '心理预期时长(分钟):', 
      cls: 'modal-label' 
    }).style.fontWeight = "bold";

    const durationInput = contentEl.createEl('input', { type: 'number' });
    durationInput.setAttrs({ min: '1', value: '10' });
    Object.assign(durationInput.style, {
      width: "100%",
      padding: "12px",
      fontSize: "16px",
      marginTop: "5px",
      marginBottom: "20px"
    });
    
    // 4. 创建按钮容器
    const buttonContainer = contentEl.createEl('div', { cls: 'modal-button-container' });
    Object.assign(buttonContainer.style, {
      display: "flex",
      justifyContent: "flex-end",
      gap: "10px"
    });

    // 5. 创建确认按钮
    const confirmBtn = buttonContainer.createEl('button', { text: '添加' });
    Object.assign(confirmBtn.style, {
      padding: "8px 15px",
      backgroundColor: "#4CAF50",
      color: "white"
    });
    confirmBtn.addEventListener('click', () => {
      const projectName = nameInput.value.trim();
      const duration = parseInt(durationInput.value, 10);
      
      if (!projectName || isNaN(duration) || duration <= 0) {
        new Notice('请输入有效的活动名称和时长！', 3000); // 使用Obsidian的Notice提示
        return;
      }
      
      this.onSubmit(projectName, duration); // 调用传入的回调函数，将数据传出
      this.close(); // 关闭模态窗口
    });

    // 6. 创建取消按钮
    const cancelBtn = buttonContainer.createEl('button', { text: '取消' });
    cancelBtn.style.padding = "8px 15px";
    cancelBtn.addEventListener('click', () => {
      this.close(); // 关闭模态窗口
    });

    // 自动聚焦到输入框，方便用户直接输入
    // 使用 setTimeout 确保元素完全渲染后再聚焦
    setTimeout(() => nameInput.focus(), 50);
  }

  // onClose 是 Modal 的生命周期方法，当窗口关闭时自动执行
  onClose() {
    // 清空内容，防止内存泄漏和UI残留
    this.contentEl.empty();
  }
}

// =========================================================================
//  第 2 部分: 新的、精简的 showAddActivityAfterForm 函数
// =========================================================================
function showAddActivityAfterForm(afterIndex) {
  // 安全检查：确保目标索引有效
  const targetActivity = currentPhase.activities[afterIndex];
  if (!targetActivity) {
    console.error("showAddActivityAfterForm 调用失败：无效的索引", afterIndex);
    new Notice("无法添加活动，因为找不到目标位置。", 4000);
    return;
  }

  // 定义当用户在模态窗口中点击“确认”后要执行的操作
  const handleSubmit = (projectName, duration) => {
    const newActivity = {
      id: generateId(), // 确保您的 generateId() 函数可用
      project: projectName,
      expectedDuration: duration,
      status: 'pending',
      isStartTimeFixed: false
    };
    
    // 1. 在指定位置后插入新活动
    currentPhase.activities.splice(afterIndex + 1, 0, newActivity);
    
    // 2. 重新计算和保存
    allocateRemainingTime(); // 确保您的 allocateRemainingTime() 函数可用
    debouncedSave();         // 确保您的 debouncedSave() 函数可用
    
    // 3. 更新执行列表的UI (如果您有这个函数)
    // 如果没有 renderExecutionList，请确保有其他机制来刷新列表
    renderExecutionList();
    if (currentPhase.status === 'active') {
      updateExecutionDisplay();
    }

    // 4. 显示成功提示
    statusEl.innerHTML = ''; // 确保 statusEl 元素可用
    statusEl.createEl("div", {
      text: "✅ 活动已添加，数据已自动保存到 JSON",
      attr: {style: "color: #4CAF50; background-color: #e8f5e9; padding: 5px; border-radius: 3px;"}
    });

    new Notice(`已成功添加活动: "${projectName}"`, 3000);
  };
  
  // 创建并打开新的模态窗口实例
  new AddActivityModal(app, afterIndex, handleSubmit).open();
}


