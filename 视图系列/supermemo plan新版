// 保存计划到 JSON 文件（参考 GTD 的简洁写法）
async function savePlanToJSON(phase) {
    console.log("=== savePlanToJSON 开始 ===");
    console.log("PLAN_FILE:", PLAN_FILE);
    if (!phase) {
        console.log("phase 为空，返回 false");
        return false;
    }
    try {
        const planData = {
            id: phase.id || generateId(),  // 使用 generateId 而不是 generateActivityId
            created: phase.created || new Date().toISOString(),
            startTime: phase.startTime,
            plannedDuration: phase.plannedDuration,
            resumePlan: phase.resumePlan || null,
            activities: phase.activities.map(a => ({
                id: a.id,
                project: a.project,
                expectedDuration: a.expectedDuration,
                allocatedDuration: a.allocatedDuration,
                status: a.status,
                isStartTimeFixed: a.isStartTimeFixed,
                expectedStart: a.expectedStart,
                expectedEnd: a.expectedEnd,
                // 新增：保存实际时间（用于已完成活动的历史记录）
                actualStart: a.actualStart,
                actualEnd: a.actualEnd,
                // 保存体验和评分
                experience: a.experience || "",
                rating: a.rating || 0,
                // 预留位：未来可扩展的自定义字段
            }))
        };
        const jsonString = JSON.stringify(planData, null, 2);
        console.log("JSON 数据准备完毕，长度:", jsonString.length);

        // 检查文件是否存在
        const fileExists = await app.vault.adapter.exists(PLAN_FILE);
        console.log("文件是否存在:", fileExists);

        const file = app.vault.getAbstractFileByPath(PLAN_FILE);
        console.log("getAbstractFileByPath 结果:", file);

        if (file) {
            console.log("执行 modify...");
            await app.vault.modify(file, jsonString);
        } else {
            console.log("执行 create...");
            await app.vault.create(PLAN_FILE, jsonString);
        }
        console.log("✅ 计划已保存:", PLAN_FILE);
        return true;
    } catch (e) {
        console.error("❌ 保存计划失败:", e);
        console.error("错误详情:", e.message, e.stack);
        return false;
    }
}

// 从 JSON 文件加载计划
async function loadPlanFromJSON() {
    console.log("=== loadPlanFromJSON 开始 ===");
    console.log("PLAN_FILE:", PLAN_FILE);
    try {
        const fileExists = await app.vault.adapter.exists(PLAN_FILE);
        console.log("文件是否存在:", fileExists);

        if (fileExists) {
            const content = await app.vault.adapter.read(PLAN_FILE);
            console.log("文件内容长度:", content.length);
            const data = JSON.parse(content);
            console.log("JSON 解析成功，活动数量:", data.activities?.length);

            // 检测是否有执行中的活动，决定阶段状态
            const hasActiveActivity = data.activities.some(a => a.status === 'in-progress');
            const hasCompletedActivity = data.activities.some(a => a.status === 'completed');
            const detectedStatus = (hasActiveActivity || hasCompletedActivity) ? 'active' : 'planning';
            console.log("检测到的状态:", detectedStatus);

            // 转换为 Phase 对象（保留原有的 actualStart, actualEnd 等数据）
            return {
                id: data.id,
                created: data.created,
                startTime: data.startTime,
                plannedDuration: data.plannedDuration,
                resumePlan: data.resumePlan || null,
                status: detectedStatus,  // 根据活动状态动态检测
                activities: data.activities.map(a => ({
                    ...a,
                    originalTimestamp: a.id,
                    experience: a.experience || "",
                    rating: a.rating || 0,
                    // 注意：actualStart 和 actualEnd 应该从 JSON 数据中保留
                    // 预留位：未来可扩展的自定义字段
                })),
                totalExpectedDuration: data.activities.reduce((sum, a) => sum + a.expectedDuration, 0),
                lastTransitionTime: new Date(data.startTime)
            };
        } else {
            console.log("文件不存在，返回 null");
        }
    } catch (e) {
        console.error("从 JSON 加载计划失败:", e);
        console.error("错误详情:", e.message, e.stack);
    }
    return null;
}

