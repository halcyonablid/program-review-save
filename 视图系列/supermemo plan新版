  onClose() {
    this.contentEl.empty();
  }
}

class ResumeQueueModal extends Modal {
  constructor(app, defaultStartTime, defaultDuration, nextActivity, currentActivity, onSubmit) {
    super(app);
    this.defaultStartTime = defaultStartTime;
    this.defaultDuration = defaultDuration;
    this.nextActivity = nextActivity;
    this.currentActivity = currentActivity;
    this.onSubmit = onSubmit;
  }

  onOpen() {
    const { contentEl } = this;

    contentEl.createEl('h4', { text: '接续后续事项' });

    const infoEl = contentEl.createEl('div', { cls: 'modal-info-text' });
    infoEl.style.marginBottom = '12px';
    infoEl.innerHTML = `
      <div>将从 <strong>${this.nextActivity.project}</strong> 开始接续后续队列。</div>
      <div style="margin-top: 6px; color: var(--text-muted); font-size: 12px;">
        ${this.currentActivity ? `当前进行中的「${this.currentActivity.project}」会在新的接续时间点收口。` : '当前没有进行中的事项，会直接从下一个未开始事项起步。'}
      </div>
    `;

    contentEl.createEl('label', { text: '新的开始时间:' }).style.fontWeight = 'bold';
    const startInput = contentEl.createEl('input', { type: 'datetime-local' });
    startInput.setAttrs({ value: formatDateTimeLocal(this.defaultStartTime) });
    startInput.style.width = '100%';
    startInput.style.marginTop = '5px';
    startInput.style.marginBottom = '15px';

    contentEl.createEl('label', { text: '后续阶段总时长(分钟):' }).style.fontWeight = 'bold';
    const durationInput = contentEl.createEl('input', { type: 'number' });
    durationInput.setAttrs({ min: '1', value: String(this.defaultDuration) });
    durationInput.style.width = '100%';
    durationInput.style.marginTop = '5px';

    const buttonContainer = contentEl.createEl('div', { cls: 'modal-button-container' });
    buttonContainer.style.marginTop = '15px';
    buttonContainer.style.display = 'flex';
    buttonContainer.style.gap = '10px';

    const confirmBtn = buttonContainer.createEl('button', {
      text: '确认接续',
      cls: 'mod-cta'
    });
    confirmBtn.style.flex = '1';

    const cancelBtn = buttonContainer.createEl('button', { text: '取消' });
    cancelBtn.style.flex = '1';

    confirmBtn.addEventListener('click', () => {
      const startValue = startInput.value;
      const durationValue = Number(durationInput.value);

      if (!startValue) {
        new Notice('请选择新的开始时间', 3000);
        return;
      }

      if (!Number.isFinite(durationValue) || durationValue <= 0) {
        new Notice('请输入有效的后续阶段总时长', 3000);
        return;
      }

      const parsedStart = new Date(startValue);
      if (Number.isNaN(parsedStart.getTime())) {
        new Notice('开始时间格式无效', 3000);
        return;
      }

      const success = this.onSubmit(parsedStart, durationValue);
      if (success !== false) {
        this.close();
      }
    });

    cancelBtn.addEventListener('click', () => this.close());

    setTimeout(() => startInput.focus(), 50);
  }

  onClose() {
    this.contentEl.empty();
  }
}

// =========================================================================
// 固定开始时间弹窗
// =========================================================================
class FixedStartTimeModal extends Modal {
  // 构造函数接收 app 实例、活动对象、以及回调函数
  constructor(app, activity, onSubmit) {
    super(app);
    this.activity = activity;
    this.onSubmit = onSubmit;
  }

  // onOpen 是 Modal 的生命周期方法，当窗口打开时自动执行
  onOpen() {
    const { contentEl } = this;

    // --- 开始构建模态窗口的内部 UI ---

    // 1. 设置标题
    contentEl.createEl('h4', {
      text: `固定 "${this.activity.project}" 的开始时间`,
      cls: 'modal-title'
    }).style.marginBottom = "15px";

    // 2. 显示当前活动信息
    contentEl.createEl('div', {
      cls: 'modal-info-text'
    }).innerHTML = `
      <span>心理预期: <strong>${formatDuration(this.activity.expectedDuration)}</strong></span>
      <br>
      <span style="color: #666; font-size: 12px;">设置此活动的固定开始时间，后续活动将从该时间点重新分配</span>
    `;
    contentEl.lastChild.style.marginBottom = '15px';

    // 3. 添加时间选择区域
    contentEl.createEl('label', {
      text: '固定开始时间:',
      cls: 'modal-label'
    }).style.fontWeight = "bold";

    // 默认值：如果已有固定时间则使用，否则使用当前时间
    const now = new Date();
    const defaultTime = this.activity.expectedStart
      ? `${new Date(this.activity.expectedStart).getHours().toString().padStart(2, '0')}:${new Date(this.activity.expectedStart).getMinutes().toString().padStart(2, '0')}`
      : `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;

    const timeInput = contentEl.createEl('input', { type: 'time' });
    timeInput.setAttrs({ value: defaultTime });
    timeInput.style.marginTop = '5px';
    timeInput.style.marginBottom = '15px';
    timeInput.style.padding = '8px';
    timeInput.style.width = '100%';

    // 4. 创建按钮容器
    const buttonContainer = contentEl.createEl('div', { cls: 'modal-button-container' });
    buttonContainer.style.marginTop = '15px';
    buttonContainer.style.display = 'flex';
    buttonContainer.style.gap = '10px';

    // 5. 创建确认按钮
    const confirmBtn = buttonContainer.createEl('button', {
      text: '确认固定',
      cls: 'mod-cta'
    });
    confirmBtn.style.flex = '1';
    confirmBtn.style.padding = '8px 15px';

    // 6. 创建取消按钮
    const cancelBtn = buttonContainer.createEl('button', { text: '取消' });
    cancelBtn.style.flex = '1';
    cancelBtn.style.padding = '8px 15px';

    // 7. 如果已固定，提供"取消固定"选项
    if (this.activity.isStartTimeFixed) {
      const unsetBtn = buttonContainer.createEl('button', {
        text: '取消固定',
        cls: 'mod-warning'
      });
      unsetBtn.style.flex = '1';
      unsetBtn.style.padding = '8px 15px';
      unsetBtn.style.backgroundColor = '#f44336';
      unsetBtn.style.color = 'white';

      unsetBtn.addEventListener('click', () => {
        this.onSubmit(null); // null 表示取消固定
        this.close();
      });
    }

    confirmBtn.addEventListener('click', () => {
      const timeValue = timeInput.value;

      if (!timeValue) {
        new Notice('请选择开始时间！', 3000);
        return;
      }

      // 解析时间
      const [hours, minutes] = timeValue.split(':').map(Number);
      const fixedTime = new Date();
      fixedTime.setHours(hours, minutes, 0, 0);

      // 验证时间是否在计划范围内
      const activePlan = getActivePlanConfig();
      const plannedEndTime = new Date(activePlan.startTime);
      plannedEndTime.setMinutes(plannedEndTime.getMinutes() + activePlan.plannedDuration);

      if (fixedTime < new Date(activePlan.startTime)) {
        new Notice('固定时间不能早于计划开始时间！', 3000);
        return;
      }

      if (fixedTime > plannedEndTime) {
        new Notice('固定时间不能晚于计划结束时间！', 3000);
        return;
      }

      this.onSubmit(fixedTime); // 传入固定的 Date 对象
      this.close();
    });

    cancelBtn.addEventListener('click', () => {
      this.close();
    });

    // 自动聚焦到时间输入框
    setTimeout(() => timeInput.focus(), 50);
  }

  // onClose 是 Modal 的生命周期方法，当窗口关闭时自动执行
  onClose() {
    this.contentEl.empty();
  }
}

// =========================================================================
// 显示固定开始时间弹窗
// =========================================================================
function showFixedStartTimeModal(activity) {
  // 安全检查
  if (!currentPhase || currentPhase.status !== 'active') {
    statusEl.innerHTML = '';
    statusEl.createEl("div", {
      text: "没有正在执行的计划",
      attr: {style: "color: red; background-color: #ffebee; padding: 8px; border-radius: 3px; margin: 10px 0;"}
    });
    return;
  }

  if (!activity || activity.status !== 'pending') {
    new Notice('只能固定待开始活动的开始时间', 3000);
    return;
  }

  // 定义当用户在模态窗口中点击"确认固定"后要执行的操作
  const handleSubmit = (fixedTime) => {
    if (fixedTime === null) {
      // 取消固定
      activity.isStartTimeFixed = false;
      activity.expectedStart = null;
      new Notice('已取消固定开始时间');
    } else {
      // 设置固定时间
      activity.isStartTimeFixed = true;
      activity.expectedStart = new Date(fixedTime);
      new Notice(`已固定开始时间: ${formatTime(fixedTime)}`);
    }

    // 重新分配时间
    allocateRemainingTime();
    debouncedSave();
    renderExecutionList();
    if (currentPhase.status === 'active') {
      updateExecutionDisplay();
    }
  };

  // 创建并打开模态窗口
  new FixedStartTimeModal(app, activity, handleSubmit).open();
}


