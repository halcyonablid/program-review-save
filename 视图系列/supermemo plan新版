}

function showResumeQueueModal() {
  if (!currentPhase || currentPhase.status !== 'active') {
    new Notice('没有正在执行的计划', 3000);
    return;
  }

  const nextPending = currentPhase.activities.find(activity => activity.status === 'pending');
  if (!nextPending) {
    new Notice('没有可接续的未开始事项', 3000);
    return;
  }

  const currentActivity = currentPhase.activities.find(activity => activity.status === 'in-progress') || null;
  const defaultDuration = Math.max(
    1,
    Math.round(
      currentPhase.activities
        .filter(activity => activity.status === 'pending')
        .reduce((sum, activity) => sum + Number(activity.allocatedDuration || activity.expectedDuration || 0), 0)
    )
  );

  const handleSubmit = (resumeStartTime, remainingDuration) => {
    return resumeRemainingQueue(resumeStartTime, remainingDuration);
  };

  new ResumeQueueModal(app, new Date(), defaultDuration, nextPending, currentActivity, handleSubmit).open();
}


// 延长阶段总时长的函数
function extendPhaseDuration(extraMinutes) {
  if (!currentPhase) return;
  
  const activePlan = getActivePlanConfig();

  // 保存原始时长用于消息显示
  const originalDuration = activePlan.plannedDuration;
  
  // 更新总时长
  if (activePlan.isResumePlan) {
    currentPhase.resumePlan.plannedDuration = originalDuration + extraMinutes;
  } else {
    currentPhase.plannedDuration += extraMinutes;
  }
  
  // 重新分配剩余时间
  allocateRemainingTime();
  debouncedSave();
  // 更新UI
  updateExecutionDisplay();
  

  
  // 显示成功消息
  statusEl.innerHTML = '';
  statusEl.createEl("div", {
    text: `总时长已从 ${formatDuration(originalDuration)} 延长至 ${formatDuration(originalDuration + extraMinutes)}`,
    attr: {style: "color: green; background-color: #e8f5e9; padding: 8px; border-radius: 3px; margin: 10px 0;"}
  });
  
  // 提示保存
  const savePrompt = statusEl.createEl("div", {
    text: "请点击「保存当前状态」按钮以保存更改到备份",
    attr: {style: "color: #ff9800; margin-top: 5px;"}
  });
}

function resumeRemainingQueue(resumeStartTime, remainingDuration) {
  if (!currentPhase || currentPhase.status !== 'active') return false;

  const nextPendingIndex = currentPhase.activities.findIndex(activity => activity.status === 'pending');
  if (nextPendingIndex === -1) {
    new Notice('没有可接续的未开始事项', 3000);
    return false;
  }

  const nextPending = currentPhase.activities[nextPendingIndex];
  const currentActivity = currentPhase.activities.find(activity => activity.status === 'in-progress') || null;

  if (currentActivity?.actualStart && resumeStartTime < new Date(currentActivity.actualStart)) {
    new Notice('新的接续时间不能早于当前事项的开始时间', 3000);
    return false;
  }

  const latestCompletedEnd = currentPhase.activities.reduce((latest, activity) => {
    if (activity.status !== 'completed' || !activity.actualEnd) return latest;
    const activityEnd = new Date(activity.actualEnd);
    return !latest || activityEnd > latest ? activityEnd : latest;
  }, null);

  if (latestCompletedEnd && resumeStartTime < latestCompletedEnd) {
    new Notice('新的接续时间不能早于已完成事项的结束时间', 3000);
    return false;
  }

  if (currentActivity) {
    currentActivity.status = 'completed';
    if (!currentActivity.actualStart) {
      currentActivity.actualStart = new Date(resumeStartTime);
    }
