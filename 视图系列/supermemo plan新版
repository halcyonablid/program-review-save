      cls: 'modal-info-text' // 添加一个类名方便样式调整
    }).innerHTML = `<span>${currentDurationLabel}: <strong>${formatDuration(activePlan.plannedDuration)}</strong></span>`;
    contentEl.lastChild.style.marginBottom = '10px';

    // 3. 添加时长输入区域
    contentEl.createEl('label', { text: '延长时间(分钟):' });
    const durationInput = contentEl.createEl('input', { type: 'number' });
    durationInput.setAttrs({ min: '1', value: '15' });
