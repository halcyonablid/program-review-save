function getActivityPlannedMinutes(activity) {
  return Math.max(0, Number(activity?.allocatedDuration || activity?.expectedDuration || 0));
}

function getActivityElapsedMinutes(activity, now = new Date()) {
  if (!activity || !activity.actualStart) return 0;
  return Math.max(0, (now - new Date(activity.actualStart)) / (60 * 1000));
}

function getActivityProgressMinutes(activity, now = new Date()) {
  if (!activity) return 0;
  const plannedMinutes = getActivityPlannedMinutes(activity);

  if (activity.status === 'completed') {
    if (activity.actualStart && activity.actualEnd) {
      return Math.max(0, (new Date(activity.actualEnd) - new Date(activity.actualStart)) / (60 * 1000));
    }
    return plannedMinutes;
  }

  if (activity.status === 'in-progress') {
    const elapsedMinutes = getActivityElapsedMinutes(activity, now);
    return plannedMinutes > 0 ? Math.min(plannedMinutes, elapsedMinutes) : elapsedMinutes;
  }

  return 0;
}

function getPhaseProgressMetrics(now = new Date()) {
  if (!currentPhase) {
    return {
      plannedMinutes: 0,
      progressedMinutes: 0,
      remainingMinutes: 0,
      progressPercent: 0
    };
  }

  const activePlan = getActivePlanConfig();
  const plannedMinutes = Math.max(0, Number(activePlan.plannedDuration) || 0);
  const resumeStartIndex = getResumePlanStartIndex();
  const scopedActivities = resumeStartIndex >= 0
    ? currentPhase.activities.slice(resumeStartIndex)
    : currentPhase.activities;
  const allCompleted = scopedActivities.length > 0 &&
    scopedActivities.every(activity => activity.status === 'completed');
  const rawProgressedMinutes = allCompleted
    ? plannedMinutes
    : scopedActivities.reduce((sum, activity) => sum + getActivityProgressMinutes(activity, now), 0);
  const progressedMinutes = plannedMinutes > 0
    ? Math.min(plannedMinutes, Math.max(0, rawProgressedMinutes))
    : 0;
  const remainingMinutes = Math.max(0, plannedMinutes - progressedMinutes);
  const progressPercent = plannedMinutes > 0 ? Math.min(100, (progressedMinutes / plannedMinutes) * 100) : 0;

  return {
    plannedMinutes,
    progressedMinutes,
    remainingMinutes,
    progressPercent
  };
}

// 同步单个活动进度条宽度
function syncActivityProgressBar(activity) {
  if (!activity || activity.status !== 'in-progress') return;
  const barEl = containerEl.querySelector(`.activity-progress-bar[data-activity-id=\"${activity.id}\"]`);
  if (!barEl) return;
  const total = getActivityPlannedMinutes(activity);
  if (total <= 0) {
    barEl.style.width = '0%';
    return;
  }
  const pct = Math.min(100, Math.max(0, (getActivityProgressMinutes(activity) / total) * 100));
  barEl.style.width = `${pct}%`;
}

// 刷新当前活动卡片上的数字/剩余显示
function updateActivityLiveUI(activity, phaseRemainingMinutes = null) {
  if (!activity || activity.status !== 'in-progress') return;

  const now = new Date();
  const elapsed = getActivityElapsedMinutes(activity, now);
  const total = getActivityPlannedMinutes(activity);
  const remaining = Math.max(0, total - elapsed);

  // 更新时间文本
  const actualEl = containerEl.querySelector(`.activity-actual-text[data-activity-id=\"${activity.id}\"]`);
  if (actualEl) {
    actualEl.textContent = `${formatDuration(elapsed)} / ${formatDuration(total)} (本活动)`;
  }

  // 更新阶段剩余文本（如果存在）
  const phaseEl = containerEl.querySelector(`.activity-phase-remaining[data-activity-id=\"${activity.id}\"]`);
  if (phaseEl) {
    const text = phaseRemainingMinutes != null
      ? `阶段剩余: ${formatDuration(phaseRemainingMinutes)}`
      : phaseEl.textContent; // fallback
    phaseEl.textContent = text;
  }

  // 同步进度条
  syncActivityProgressBar(activity);
}

// 更新执行状态显示 - 修复进度条显示问题
// 更新执行显示(包括进度条和当前活动) - 优化版：更清晰的进度显示
function updateExecutionDisplay() {
  if (!currentPhase || currentPhase.status !== 'active') return;
  
  const now = new Date();
  const activePlan = getActivePlanConfig();
  const startTime = new Date(activePlan.startTime);
  const plannedEndTime = new Date(startTime.getTime() + activePlan.plannedDuration * 60 * 1000);
  const progressMetrics = getPhaseProgressMetrics(now);
  
  // 更新进度条
  progressBar.style.width = `${progressMetrics.progressPercent}%`;
  progressBar.setAttribute("aria-valuenow", Math.floor(progressMetrics.progressPercent));
  
  const remainingMinutes = progressMetrics.remainingMinutes;
  const elapsedMinutes = progressMetrics.progressedMinutes;
  const totalMinutes = progressMetrics.plannedMinutes;

  // 更新进度文本，和下方事项推进量保持同一口径
  progressText.innerHTML = `开始: ${formatTime(startTime)} | 结束: ${formatTime(plannedEndTime)} | ` +
                         `已推进: ${formatDuration(elapsedMinutes)} | 总时长: ${formatDuration(totalMinutes)} | ` +
                         `剩余: ${formatDuration(remainingMinutes)} | ` +
                         `进度: ${Math.floor(progressMetrics.progressPercent)}%`;

  // 查找当前进行中的活动
  const currentActivity = currentPhase.activities.find(a => a.status === 'in-progress');
  
  // 更新当前活动卡片的实时数值与进度背景
  if (currentActivity) {
    updateActivityLiveUI(currentActivity, remainingMinutes);
  }
  
  // 显示当前活动信息
  if (currentActivity) {
    currentActivityName.innerHTML = `<strong>${currentActivity.project}</strong>`;
    
    // 如果缺少 actualStart，立即补齐，避免读/预览模式不刷新
    if (!currentActivity.actualStart) {
      currentActivity.actualStart = new Date();
      debouncedSave();
    }

    // 计算当前活动已进行时间
    const activityElapsed = getActivityElapsedMinutes(currentActivity, now);
    const allocatedTime = getActivityPlannedMinutes(currentActivity);
    const activityRemaining = Math.max(0, allocatedTime - getActivityProgressMinutes(currentActivity, now));
    
    // 更新当前活动卡片上的进度背景
    syncActivityProgressBar(currentActivity);

    // 显示当前活动的时间信息
    currentActivityTime.innerHTML = `已进行: ${formatDuration(activityElapsed)} | ` +
                                   `预计剩余: ${formatDuration(activityRemaining)} | ` +
                                   `总计划: ${formatDuration(allocatedTime)}`;
  } else {
    currentActivityName.textContent = "无进行中的活动";
    currentActivityTime.textContent = "";
  }
  
  // 查找下一个待处理的活动
  const nextActivityIndex = currentPhase.activities.findIndex(a => a.status === 'pending');
  
  // 显示下一个活动信息
  if (nextActivityIndex !== -1) {
    const nextActivity = currentPhase.activities[nextActivityIndex];
    nextActivityName.innerHTML = `下一个: <strong>${nextActivity.project}</strong> (计划时间: ${formatDuration(nextActivity.allocatedDuration || nextActivity.expectedDuration)})`;
  } else {
    nextActivityName.textContent = "没有更多待处理的活动";
  }
  
  // ==================== 【新增】实时更新剩余时间统计 ====================
  renderRemainingTimeStats();
}


