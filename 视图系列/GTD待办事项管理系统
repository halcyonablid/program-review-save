    const getCurrentNoteLinkName = () => {
        const name = String(dv.current()?.file?.name || "");
        if (name) return name.replace(/\.md$/i, "");
        const path = String(dv.current()?.file?.path || "");
        const fallback = path.split("/").pop() || "";
