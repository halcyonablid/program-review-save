      "createdAt": "2026-03-05 16:41:00",
      "updatedAt": "2026-03-05 17:00:00"
    }
  },
  "paradigmChildrenByParent": {
    "pg_xxx::__root__": ["pgItem_p1"]
  },
  "paradigmToTabItemMapByTab": {
    "tab_xxx::pgItem_p1": "item_p1_in_tab_xxx"
  },
