                    e.dataTransfer.effectAllowed = "move";
                    e.dataTransfer.setData("text/plain", tab.id);
                    setTimeout(() => wrapper.classList.add("is-dragging"), 0);
                });
                wrapper.addEventListener("dragend", (e) => {
                    e.stopPropagation();
                    window.workspaceTabCurrentDragId = null;
