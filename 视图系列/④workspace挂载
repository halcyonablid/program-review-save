            const file = app.vault.getAbstractFileByPath(TASK_NOTE_BINDINGS_PATH);
            if (file) {
                await app.vault.modify(file, jsonString);
            } else {
                await app.vault.create(TASK_NOTE_BINDINGS_PATH, jsonString);
