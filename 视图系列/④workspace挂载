    }
  },
  "tabOrder": ["tab_xxx"],
  "itemsById": {
    "item_x1": {
      "id": "item_x1",
      "title": "需求澄清",
      "parentId": null,
      "tabId": "tab_xxx",
      "sourceType": "tab",
